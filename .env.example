# Auth (NextAuth + Google OAuth)
AUTH_SECRET=generate-with-openssl-rand-base64-32
# 生产环境可选：AUTH_URL=https://your-domain.com
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# DeepSeek — 文本 Agent（必填）
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# OpenAI — 语音 STT/TTS（Whisper + TTS，必填才能使用语音按钮）
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy
OPENAI_WHISPER_MODEL=whisper-1

# 语音功能开关（默认开启；还需 OPENAI_API_KEY 才能真正可用）
VOICE_STT_ENABLED=true
VOICE_TTS_ENABLED=true

# Database（Vercel 部署必填，Production/Preview/Development 都要配置）
# 本地 dev 使用此 URL；Prisma 迁移请运行: npm run db:deploy
DATABASE_URL=postgresql://user:password@localhost:5433/ai_voice_assistant
